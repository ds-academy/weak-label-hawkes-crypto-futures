# Python build artifacts
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Virtual environments
.venv/
venv/

# LaTeX intermediates that the paper-render pipeline produces. The
# rendered .tex, .bbl, and .pdf are intentionally tracked; everything
# else can be regenerated by run.sh and should not be committed.
**/*.aux
**/*.log
**/*.out
**/*.toc
**/*.blg
**/*.fls
**/*.fdb_latexmk
**/*.synctex.gz

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/
